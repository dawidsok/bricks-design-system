{
  "$schema": "https://design-tokens.github.io/community-group/format/schema.json",
  "name": "Sunny Brutalist",
  "version": "0.1.0",
  "description": "Brutalist monochrome design tokens extracted from the Sunny 16 app.",
  "color": {
    "$type": "color",
    "base": {
      "black": { "$value": "#000000" },
      "white": { "$value": "#ffffff" },
      "stone-100": { "$value": "#f5f5f4" },
      "orange-400": { "$value": "#fb923c" },
      "orange-500": { "$value": "#f97316" }
    },
    "surface": {
      "default": {
        "light": { "$value": "#f5f5f4" },
        "dark": { "$value": "#000000" }
      },
      "inverse": {
        "light": { "$value": "#000000" },
        "dark": { "$value": "#ffffff" }
      }
    },
    "text": {
      "primary": {
        "light": { "$value": "#000000" },
        "dark": { "$value": "#ffffff" }
      },
      "secondary": {
        "light": { "$value": "rgba(0, 0, 0, 0.4)" },
        "dark": { "$value": "rgba(255, 255, 255, 0.4)" }
      },
      "tertiary": {
        "light": { "$value": "rgba(0, 0, 0, 0.2)" },
        "dark": { "$value": "rgba(255, 255, 255, 0.2)" }
      },
      "muted": {
        "light": { "$value": "rgba(0, 0, 0, 0.3)" },
        "dark": { "$value": "rgba(255, 255, 255, 0.3)" }
      },
      "subtle": {
        "light": { "$value": "rgba(0, 0, 0, 0.6)" },
        "dark": { "$value": "rgba(255, 255, 255, 0.6)" }
      },
      "alert": {
        "light": { "$value": "#f97316" },
        "dark": { "$value": "#fb923c" }
      }
    },
    "border": {
      "hairline": {
        "light": { "$value": "rgba(0, 0, 0, 0.2)" },
        "dark": { "$value": "rgba(255, 255, 255, 0.2)" }
      },
      "muted": {
        "light": { "$value": "rgba(0, 0, 0, 0.3)" },
        "dark": { "$value": "rgba(255, 255, 255, 0.3)" }
      },
      "hover": {
        "light": { "$value": "rgba(0, 0, 0, 0.6)" },
        "dark": { "$value": "rgba(255, 255, 255, 0.6)" }
      },
      "strong": {
        "light": { "$value": "#000000" },
        "dark": { "$value": "#ffffff" }
      }
    },
    "rule": {
      "center": {
        "light": { "$value": "rgba(0, 0, 0, 0.3)" },
        "dark": { "$value": "rgba(255, 255, 255, 0.3)" }
      }
    }
  },
  "font": {
    "family": {
      "mono": {
        "$type": "fontFamily",
        "$value": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace"
      }
    },
    "size": {
      "$type": "dimension",
      "xs": { "$value": "0.75rem" },
      "sm": { "$value": "0.875rem" },
      "base": { "$value": "1rem" },
      "lg": { "$value": "1.125rem" },
      "xl": { "$value": "1.5rem" },
      "display": { "$value": "3.75rem" },
      "metadata": { "$value": "0.625rem" }
    },
    "weight": {
      "$type": "fontWeight",
      "regular": { "$value": "400" },
      "bold": { "$value": "700" },
      "black": { "$value": "900" }
    },
    "lineHeight": {
      "$type": "dimension",
      "none": { "$value": "1" },
      "tight": { "$value": "1.1" },
      "normal": { "$value": "1.5" }
    },
    "letterSpacing": {
      "$type": "dimension",
      "label": { "$value": "0.1em" },
      "readout": { "$value": "0.1em" },
      "wordmark": { "$value": "0.4em" }
    }
  },
  "space": {
    "$type": "dimension",
    "0": { "$value": "0" },
    "1": { "$value": "0.25rem" },
    "2": { "$value": "0.5rem" },
    "3": { "$value": "0.75rem" },
    "4": { "$value": "1rem" },
    "6": { "$value": "1.5rem" },
    "8": { "$value": "2rem" },
    "10": { "$value": "2.5rem" }
  },
  "size": {
    "$type": "dimension",
    "control": { "$value": "2rem" },
    "wheel-track-height": { "$value": "3.5rem" },
    "wheel-item-default": { "$value": "5rem" },
    "wheel-item-compact": { "$value": "2rem" },
    "wheel-item-condition": { "$value": "6rem" },
    "wheel-label-width": { "$value": "2.5rem" },
    "container-sm": { "$value": "24rem" },
    "meter-spot": { "$value": "1.5rem" }
  },
  "border": {
    "radius": {
      "$type": "dimension",
      "none": { "$value": "0" }
    },
    "width": {
      "$type": "dimension",
      "hairline": { "$value": "1px" },
      "spot": { "$value": "2px" }
    }
  },
  "opacity": {
    "$type": "number",
    "selected": { "$value": 1 },
    "inactive": { "$value": 0.3 },
    "disabled": { "$value": 0.3 },
    "secondary": { "$value": 0.4 },
    "tertiary": { "$value": 0.2 },
    "subtle": { "$value": 0.6 }
  },
  "motion": {
    "duration": {
      "$type": "duration",
      "fast": { "$value": "150ms" }
    },
    "easing": {
      "$type": "cubicBezier",
      "snap": { "$value": [0, 0, 0.2, 1] }
    }
  },
  "interaction": {
    "drag-threshold": {
      "$type": "dimension",
      "$value": "5px"
    },
    "touch-action-drum": {
      "$type": "string",
      "$value": "none"
    }
  },
  "constraints": {
    "forbidden": {
      "rounded-corners": { "$type": "boolean", "$value": true },
      "shadows": { "$type": "boolean", "$value": true },
      "gradients": { "$type": "boolean", "$value": true },
      "blur-effects": { "$type": "boolean", "$value": true },
      "proportional-type": { "$type": "boolean", "$value": true },
      "extra-accent-colors": { "$type": "boolean", "$value": true }
    }
  }
}
